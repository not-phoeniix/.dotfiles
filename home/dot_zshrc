# initially generated things
HISTFILE=~/.zsh_history
HISTSIZE=1000
SAVEHIST=1000
setopt autocd
unsetopt beep extendedglob nomatch notify
bindkey -v
bindkey '^H' backward-kill-word

zstyle :compinstall filename '/home/nikki/.zshrc'

autoload -Uz compinit
compinit

# enable colors !!
autoload -U colors && colors
PS1="%{$fg[red]%}%n%{$reset_color%}@%{$fg[blue]%}%m %{$fg[yellow]%}%~ %{$reset_color%}%%"

# prompt
autoload -U promptinit; promptinit
prompt purer

# aliases
alias ls='ls --color=auto'
alias q='exit'
alias c='clear'
alias tty-clock='tty-clock -c -C 1'
alias feh='feh --scale-down'
alias unimatrix='unimatrix -c red -l o -s 94'
alias tablet-mode='setsysmode toggle'
alias chedit='chezmoi edit'

# exports
export EDITOR="nvim"
export VISUAL="nvim"
export TERM="foot"
export TERMINAL="foot"
export GOPATH"=$HOME/Go"

# pfetch
export PF_INFO="ascii title os kernel wm shell pkgs memory"
export PF_COL1=5
export PF_COL2=7
export PF_COL3=3
pfetch

# PATH
export PATH=$PATH:~/pebble-dev/pebble-sdk-4.6-rc2-linux64/bin:~/.spicetify:~/.dotnet/tools:~/Go/bin

(cat $HOME/.cache/wal/sequences &)
