{
	"wlr/workspaces": {
		"format": "{icon}",
		"on-click": "activate",
   		"format-icons": {
   			"1": "I",
   			"2": "II",
   			"3": "III",
   			"4": "IV",
   			"5": "V",
   			"6": "VI",
   			"7": "VII",
   			"8": "пДЫ",
   			"9": "у∞Щѓ",
   			"10": "пАБ"
   		},
		"sort-by-number": true
	},

	"hyprland/window": {
		"format": "{title}"
	},
	
	"backlight": {
		"format": "{percent}% у∞Г†"
	},

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% пЦГ",
        "format-plugged": "{capacity}% пЦВ",
        "format-alt": "{time} {icon}",
    	"format-icons": ["пЦН", "пХє", "пХЇ", "пХї", "пХЉ", "пХљ", "пХЊ", "пХњ", "пЦА", "пЦБ", "пХЄ"],
        "tooltip": true,
		"bat": "BAT1"
    },

    "clock": {
        "format": "{:%I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y/%m/%d}"
    },

    "pulseaudio": {
        "format": "{volume}% {icon}", 
        "format-bluetooth-muted": "пС¶ {icon}", 
        "format-muted": "пС¶",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пКФ",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "пА®"]
        },
        "on-click": "pamixer -t",
        "on-click-middle": "pavucontrol"
    },

	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "у∞ИИ",
			"deactivated": "у±Ч§"
		},
		"timeout": 30
	},

    "tray": {
        "spacing": 10
	},

    "custom/waybar-mpris": {
        "return-type": "json",
        "exec": "waybar-mpris --order 'TITLE:ARTIST' --autofocus",
        "on-click": "waybar-mpris --send player-next",
        "escape": "true",
		"max-length": 50
    }
}
