[
    {
        "name": "main",
        "layer": "top", // Waybar at top layer
        "position": "top",
        "spacing": 10, // Gaps between modules
        "margin": 10,
		"output": ["DP-3", "eDP-1"],

        // Choose the order of the modules
        "modules-left": ["sway/workspaces", "sway/window", "sway/mode"],
        "modules-center": ["custom/waybar-mpris"],
        "modules-right": ["custom/arch-updates", "pulseaudio", "battery", "idle_inhibitor", "tray", "clock"],

        "sway/workspaces": {
            "all-outputs": false,
            "disable-scroll": true,
    		"format": "{icon}",
    		"format-icons": {
    			"1": "I",
    			"2": "II",
    			"3": "III",
    			"4": "IV",
    			"5": "V",
    			"6": "VI",
    			"7": "VII",
    			"8": "п„ӣ",
    			"9": "у°ҷҜ",
    			"10": "пҖҒ",
    		}
        },

        "sway/window": {
            "format": "{title}",
            "max-length": 40
        },

        "custom/waybar-mpris": {
            "return-type": "json",
            "exec": "waybar-mpris --order 'TITLE:ARTIST' --autofocus",
            "on-click": "waybar-mpris --send player-next",
            "escape": "true",
			"max-length": 50
        },

		"custom/arch-updates": {
			"format": "уұ§ҳ {}",
			"tooltip": "Number of updatable packages",
			"exec": "checkupdates+aur | wc -l",
			"exec-on-event": "true",
			"on-click": "foot yay",
			"on-right-click": "",
			"interval": "once",
			"escape": "true",
			"max-length": 50
		},

        "pulseaudio": {
            "format": "{volume}% {icon}", 
            "format-bluetooth-muted": "п‘Ұ {icon}", 
            "format-muted": "п‘Ұ",
            "format-icons": {
                "headphone": "пҖҘ",
                "hands-free": "п–җ",
                "headset": "пҠ”",
                "phone": "пӮ•",
                "portable": "пӮ•",
                "car": "пҶ№",
                "default": ["пҖҰ", "пҖ§", "пҖЁ"]
            },
            "on-click": "pamixer -t",
            "on-click-middle": "pavucontrol"
        },

        "battery": {
            "states": {
                // "good": 95,
                "warning": 30,
                "critical": 15
            },
            "format": "{capacity}% {icon}",
            "format-charging": "{capacity}% п–ғ",
            "format-plugged": "{capacity}% п–Ӯ",
            "format-alt": "{time} {icon}",
    		"format-icons": ["п–Қ", "п•№", "п•ә", "п•»", "п•ј", "п•Ҫ", "п•ҫ", "п•ҝ", "п–Җ", "п–Ғ", "п•ё"],
            "tooltip": true,
			"bat": "BAT1"
        },

		"idle_inhibitor": {
			"format": "{icon}",
			"format-icons": {
				"activated": "у°ҲҲ",
				"deactivated": "уұ—Ө"
			},
			"timeout": 30
		},

        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },

        "clock": {
            "format": "{:%I:%M %p}",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "format-alt": "{:%Y/%m/%d}"
        }
    }
]
