[
    {
        "name": "main",
        "layer": "top", // Waybar at top layer
        "position": "top",
        "spacing": 10, // Gaps between modules
        "margin": 10,
		"output": ["DP-3", "eDP-1"],

        // Choose the order of the modules
        "modules-left": ["sway/workspaces", "sway/window", "sway/mode"],
        "modules-center": ["custom/waybar-mpris"],
        "modules-right": ["pulseaudio", "battery", "idle_inhibitor", "tray", "clock"],

        "sway/workspaces": {
            "all-outputs": false,
            "disable-scroll": true,
    		"format": "{icon}",
    		"format-icons": {
    			"1": "I",
    			"2": "II",
    			"3": "III",
    			"4": "IV",
    			"5": "V",
    			"6": "VI",
    			"7": "VII",
