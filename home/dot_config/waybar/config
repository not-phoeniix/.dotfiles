[
    {
        "name": "main",
        "layer": "top", // Waybar at top layer
        "position": "top",
        "spacing": 10, // Gaps between modules
        "margin": 10,
		"output": ["DP-3", "eDP-1"],

		"include": [
			"~/.config/waybar/default-modules.json"
		],

        "modules-left": ["wlr/workspaces", "hyprland/window"],
        "modules-center": ["clock"],
        "modules-right": ["pulseaudio", "backlight", "battery", "tray"],

    },

    {
        "name": "secondary",
        "layer": "top", // Waybar at top layer
        "position": "top",
        "spacing": 10, // Gaps between modules
        "margin": 10,
		"output": ["HDMI-A-1"],

		"include": [
			"~/.config/waybar/default-modules.json"
		],

        "modules-left": ["sway/workspaces"],
        "modules-center": [],
        "modules-right": ["clock"],
    }
]
