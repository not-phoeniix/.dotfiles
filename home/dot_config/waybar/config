    		}
        },

        "sway/window": {
            "format": "{title}",
            "max-length": 40
        },

        "custom/waybar-mpris": {
            "return-type": "json",
            "exec": "waybar-mpris --order 'TITLE:ARTIST' --autofocus",
            "on-click": "waybar-mpris --send player-next",
            "escape": "true",
			"max-length": 50
        },

        "pulseaudio": {
            "format": "{volume}% {icon}", 
            "format-bluetooth-muted": "´ĹŽ {icon}", 
