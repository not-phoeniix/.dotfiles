[
    {
        "name": "main",
        "layer": "top", // Waybar at top layer
        "position": "top",
        "spacing": 10, // Gaps between modules
        "margin": 10,
		"output": ["DP-3", "eDP-1"],

        // Choose the order of the modules
        "modules-left": ["sway/workspaces", "sway/window", "sway/mode"],
        "modules-center": ["custom/waybar-mpris"],
        "modules-right": ["pulseaudio", "battery", "idle_inhibitor", "tray", "clock"],

        "sway/workspaces": {
            "all-outputs": false,
            "disable-scroll": true,
    		"format": "{icon}",
    		"format-icons": {
    			"1": "I",
    			"2": "II",
    			"3": "III",
    			"4": "IV",
    			"5": "V",
    			"6": "оћ•",
    			"7": "п‚¬",
    			"8": "п„›",
    			"9": "у°™Ї",
    			"10": "пЂЃ",
    		}
        },

        "sway/window": {
            "format": "{title}",
            "max-length": 40
        },

        "custom/waybar-mpris": {
            "return-type": "json",
            "exec": "waybar-mpris --order 'TITLE:ARTIST' --autofocus",
            "on-click": "waybar-mpris --send player-next",
            "escape": "true",
			"max-length": 50
        },

        "pulseaudio": {
            "format": "{volume}% {icon}", 
            "format-bluetooth-muted": "п‘¦ {icon}", 
            "format-muted": "п‘¦",
            "format-icons": {
                "headphone": "пЂҐ",
                "hands-free": "п–ђ",
                "headset": "пЉ”",
                "phone": "п‚•",
                "portable": "п‚•",
                "car": "п†№",
                "default": ["пЂ¦", "пЂ§", "пЂЁ"]
            },
            "on-click": "pamixer -t",
            "on-click-middle": "pavucontrol"
        },

        "battery": {
            "states": {
                // "good": 95,
                "warning": 30,
                "critical": 15
            },
            "format": "{capacity}% {icon}",
            "format-charging": "{capacity}% п–ѓ",
            "format-plugged": "{capacity}% п–‚",
            "format-alt": "{time} {icon}",
    		"format-icons": ["п–Ќ", "п•№", "п•є", "п•»", "п•ј", "п•Ѕ", "п•ѕ", "п•ї", "п–Ђ", "п–Ѓ", "п•ё"],
            "tooltip": true,
			"bat": "BAT1"
        },

		"idle_inhibitor": {
			"format": "{icon}",
			"format-icons": {
				"activated": "у°€€",
				"deactivated": "у±—¤"
			},
			"timeout": 30
		},

        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },

        "clock": {
            "format": "{:%I:%M %p}",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "format-alt": "{:%Y/%m/%d}"
        }
    }
]
