        },

        "battery": {
            "states": {
                // "good": 95,
                "warning": 30,
                "critical": 15
            },
            "format": "{capacity}% {icon}",
            "format-charging": "{capacity}% ´ľâ",
            "format-plugged": "{capacity}% ´ľé",
            "format-alt": "{time} {icon}",
    		"format-icons": ["´ľŹ", "´Ľ╣", "´Ľ║", "´Ľ╗", "´Ľ╝", "´ĽŻ", "´Ľż", "´Ľ┐", "´ľÇ", "´ľü", "´ĽŞ"],
