### KEYBINDS FILE

### VARIABLES ===================================================================

include variables

# mod
set $mod Mod4

# directionals
set $left h
set $down j
set $up k
set $right l

# apps
set $term foot
set $files nemo
set $menu fuzzel

# wob
set $WOBSOCK $XDG_RUNTIME_DIR/wob.sock

### KEYBINDS ====================================================================

### basic things ###
# apps
bindsym $mod+Return exec $term
bindsym $mod+Shift+Return exec $files
bindsym $mod+Control+Return exec $term btop
bindsym $mod+space exec $menu

# screen lock
bindsym $mod+End exec $swaylock

# notifications
bindsym $mod+n exec makoctl dismiss --all
bindsym $mod+Shift+n exec "for i in {1..3}; do makoctl restore; done"

# reload sway
bindsym $mod+Shift+r reload

# cpu thingy
bindsym $mod+grave exec $term ~/.config/change_cpu.sh

# exiting things
bindsym $mod+q kill
bindsym $mod+Shift+q exec swaymsg exit

# mod + mouse to edit sizes n stuff
floating_modifier $mod normal

### screenshots ###
bindsym Print exec 'grimshot --notify copy area'
bindsym Shift+Print exec 'grimshot --notify copy screen'
bindsym Control+Print exec 'grimshot --notify save area'
bindsym Control+Shift+Print exec 'grimshot --notify save screen'

### function row ###
# volume
bindsym XF86AudioRaiseVolume exec 'pamixer -i 5 && pamixer --get-volume > $WOBSOCK'
bindsym XF86AudioLowerVolume exec 'pamixer -d 5 && pamixer --get-volume > $WOBSOCK' 
bindsym XF86AudioMute exec 'pamixer -t && ( [  "$(pamixer --get-mute)" = "true" ] && echo 0 > $WOBSOCK ) || pamixer --get-volume > $WOBSOCK'

# media control
bindsym XF86AudioMedia exec 'playerctl --player=spotify,%all play-pause'
bindsym XF86AudioPlay exec 'playerctl --player=spotify,%all play-pause'
bindsym XF86AudioNext exec 'playerctl --player=spotify,%all next'
bindsym XF86AudioPrev exec 'playerctl --player=spotify,%all previous'

# they do the same thing but one's for laptop which can't do shift and multimedia at the same time :/
bindsym Shift+XF86AudioLowerVolume exec 'playerctl --player=spotify,%all volume 0.1-'
bindsym Shift+XF86AudioRaiseVolume exec 'playerctl --player=spotify,%all volume 0.1+'
bindsym Shift+F6 exec 'playerctl --player=spotify,%all volume 0.1-'
bindsym Shift+F7 exec 'playerctl --player=spotify,%all volume 0.1+'

# brightness
bindsym XF86MonBrightnessUp exec brightnessctl set +10% | sed -En 's/.*\(([0-9]+)%\).*/\1/p' > $WOBSOCK
bindsym XF86MonBrightnessDown exec brightnessctl set 10%- | sed -En 's/.*\(([0-9]+)%\).*/\1/p' > $WOBSOCK

### screen rotation ###
bindsym $mod+Alt+Up output eDP-1 transform normal;
    input 1267:10996:ELAN2514:00_04F3:2AF4 map_to_output eDP-1

bindsym $mod+Alt+Down output eDP-1 transform 180; 
    input 1267:10996:ELAN2514:00_04F3:2AF4 map_to_output eDP-1

bindsym $mod+Alt+Left output eDP-1 transform 270; 
    input 1267:10996:ELAN2514:00_04F3:2AF4 map_to_output eDP-1

bindsym $mod+Alt+Right output eDP-1 transform 90;
    input 1267:10996:ELAN2514:00_04F3:2AF4 map_to_output eDP-1

### moving things ###
# move focus
bindsym $mod+$up focus up
bindsym $mod+$down focus down
bindsym $mod+$left focus left
bindsym $mod+$right focus right

# moving windows (freeform or in tile)
bindsym $mod+Shift+$up move up 60px
bindsym $mod+Shift+$down move down 60px
bindsym $mod+Shift+$left move left 60px
bindsym $mod+Shift+$right move right 60px
bindsym $mod+Shift+g move position center

### workspaces ###
# focus on desired workspace
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# gesture switching
bindgesture swipe:left workspace next
bindgesture swipe:right workspace prev

# move focused window to desired workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# next/prev workspace
bindsym $mod+bracketright workspace next_on_output
bindsym $mod+bracketleft workspace prev_on_output
bindsym $mod+Shift+bracketright workspace next
bindsym $mod+Shift+bracketleft workspace prev

# output focus
bindsym $mod+Control+$up focus output up
bindsym $mod+Control+$down focus output down
bindsym $mod+Control+$left focus output left
bindsym $mod+Control+$right focus output right

# output moving
bindsym $mod+Control+Shift+$up move workspace output up
bindsym $mod+Control+Shift+$down move workspace output down
bindsym $mod+Control+Shift+$left move workspace output left
bindsym $mod+Control+Shift+$right move workspace output right

### layout thingies ###
# horizontal and vertical splitting
bindsym $mod+x splith
bindsym $mod+z splitv
bindsym $mod+c split none

# Switch the current container between different layout styles
bindsym $mod+i layout toggle split
bindsym $mod+o layout tabbed
bindsym $mod+p layout stacking

# fullscreen
bindsym $mod+f fullscreen

# floating thingies
bindsym $mod+s floating toggle
bindsym $mod+d focus mode_toggle
bindsym $mod+Shift+s sticky toggle

# move focus to the parent container
bindsym $mod+Page_Up focus parent
bindsym $mod+Page_Down focus child

# resizing
mode "resize" {
    bindsym $left resize shrink width 50px
    bindsym $down resize grow height 50px
    bindsym $up resize shrink height 50px
    bindsym $right resize grow width 50px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"
