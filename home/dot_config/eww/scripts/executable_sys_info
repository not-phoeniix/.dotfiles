#!/bin/sh

# ~~~ functions ~~~

get_brightness() {
    echo "$(brightnessctl get -P)"
}

set_brightness() {
    brightnessctl set $1
}

get_battery() {
    BAT=$(ls /sys/class/power_supply | grep BAT | head -n 1)
    LEVEL="$(cat /sys/class/power_supply/${BAT}/capacity)%"
    STATUS="$(cat /sys/class/power_supply/${BAT}/status)"
    OUTPUT="$LEVEL "

    if [[ $STATUS == "Charging" ]]; then
        OUTPUT+="󰂄"
    elif [[ $LEVEL > 90 ]]; then
        OUTPUT+="󰂂"
    elif [[ $LEVEL > 70 ]]; then
        OUTPUT+="󰂀"
    elif [[ $LEVEL > 50 ]]; then
        OUTPUT+="󰁾"
    elif [[ $LEVEL > 30 ]]; then
        OUTPUT+="󰁼"
    elif [[ $LEVEL > 10 ]]; then
        OUTPUT+="󰁺"
    fi

    echo $OUTPUT
}

get_battery_status() {
    BAT=$(ls /sys/class/power_supply | grep BAT | head -n 1)
    STATUS="$(cat /sys/class/power_supply/${BAT}/status)"

    echo $STATUS
}

get_vol() {
    VOLUME=$(pamixer --get-volume)
    VOLUME_HUMAN=$(pamixer --get-volume-human)
    OUTPUT=""

    DEFAULT_SINK=$(pamixer --get-default-sink)

    if [[ $VOLUME_HUMAN == "muted" ]]; then
        OUTPUT+=""
    elif [[ $DEFAULT_SINK =~ "bluez" ]]; then
        OUTPUT+=$VOLUME_HUMAN
        OUTPUT+=" 󰂯"
    elif [[ $VOLUME > 66 ]]; then
        OUTPUT+=$VOLUME_HUMAN
        OUTPUT+=" "
    elif [[ $VOLUME > 33 ]]; then
        OUTPUT+=$VOLUME_HUMAN
        OUTPUT+=" "
    else
        OUTPUT+=$VOLUME_HUMAN
        OUTPUT+=" "
    fi

    echo $OUTPUT
}

toggle_vol() {
    pamixer -t
}

# ~~~ kslfjdglkdfs ~~~

POLL_INTERVAL="0.1s"

case "$1" in
    "--get-battery")
        get_battery
        ;;

    "--get-battery-status")
        get_battery_status
        ;;

    "--get-brightness")
        get_brightness
        ;;

    "--get-vol")
        get_vol
        ;;

esac
