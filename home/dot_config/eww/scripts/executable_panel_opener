#!/bin/sh

toggle_bar() {
    # if first one exits as failed (false), bar isn't open,
    # so it executes the second command, opening bar
    eww close bar || eww open bar
}

toggle_dock() {
    eww close dock || eww open dock
}

toggle_wlsunset() {
    killall wlsunset || wlsunset &
}

toggle_ctrl() {
    CURRENT_STATE=$(eww get ctrl-opened)
    NEW_STATE="true"

    if [[ $CURRENT_STATE == "true" ]]; then
        NEW_STATE="false"
        eww close ctrl-panel
    else
        eww open ctrl-panel
        eww close cal-panel
    fi

    eww update ctrl-opened=$NEW_STATE
}

toggle_music() {
    CURRENT_STATE=$(eww get music-opened)
    NEW_STATE="true"

    if [[ $CURRENT_STATE == "true" ]]; then
        NEW_STATE="false"
        eww close music-panel
    else
        eww open music-panel
    fi

    eww update music-opened=$NEW_STATE
}

toggle_cal() {
    CURRENT_STATE=$(eww get cal-opened)
    NEW_STATE="true"

    if [[ $CURRENT_STATE == "true" ]]; then
        NEW_STATE="false"
        eww close cal-panel
    else
        eww open cal-panel
        eww close ctrl-panel
        eww update ctrl-opened=false
    fi

    eww update cal-opened=$NEW_STATE
}

case "$1" in
    "--toggle-bar")
        toggle_bar
        ;;

    "--toggle-dock")
        toggle_dock
        ;;

    "--toggle-ctrl")
        toggle_ctrl
        ;;

    "--toggle-music")
        toggle_music
        ;;

    "--toggle-cal")
        toggle_cal
        ;;
esac
