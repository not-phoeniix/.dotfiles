(defwidget cal []
  (box :class "container"
    (calendar
      :day day
      :month month
      :year year
      :class "calendar"
    )
  )
)

(defwindow cal-panel
  :monitor 0
  :geometry (geometry
    :x "10px"
    :y "10px"
    :height "200px"
    :width "200px"
    :anchor "bottom left"
  )
  :exclusive false
  (eventbox
    :onhoverlost "eww close cal-panel && eww update cal-opened=false"
    (box :orientation "v" :class "panel"
      (cal)
    )
  )
)
