# bindings
on-button-middle=dismiss-all
on-button-right=dismiss
on-button-left=invoke-default-action
on-touch=invoke-default-action

# style
padding=10
margin=20
border-radius=6
border-size=3

font=Papernotes 16
icon-path=/usr/share/icons/Papirus-Dark
background-color=#16161cFF
border-color=#e95678
text-color=#e0e0e0

max-icon-size=64
width=300
height=200

# other behavior
default-timeout=10000
ignore-timeout=0
